# ===================================
# DroSeal Project - Root .gitignore
# ===================================

# Reference folder (not tracked)
DroSeal-front/
requirements-korean/
md/

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE Settings (personal)
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Logs
*.log
logs/

# Uploads (user data)
uploads/

# Environment variables
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
.cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Node modules (frontend)
node_modules/

# Build outputs
dist/
build/
target/
out/

# Package manager locks (optional - 팀 정책에 따라)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
