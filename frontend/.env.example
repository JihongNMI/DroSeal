# Environment Variables for DroSeal React Frontend
# 
# This file documents the environment variables used in the application.
# Copy this file to .env.local and fill in your actual values.
#
# IMPORTANT: In Vite, only variables prefixed with VITE_ are exposed to your
# client-side code. They are statically replaced at build time.
#
# Access environment variables in your code using:
#   import.meta.env.VITE_VARIABLE_NAME
#
# Example:
#   const apiUrl = import.meta.env.VITE_API_URL
#   const appTitle = import.meta.env.VITE_APP_TITLE

# API Configuration
# The base URL for the backend API
VITE_API_URL=http://localhost:3000/api

# Application Configuration
# The title displayed in the browser tab and application header
VITE_APP_TITLE=DroSeal - Collection Manager
